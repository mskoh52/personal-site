{
  "name": "app-index",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "serve": "node scripts/serve.mjs --target=local",
    "serve:phone": "node scripts/serve.mjs --target=phone",
    "serve:build": "node scripts/serve.mjs --target=local --build-first",
    "serve:build:phone": "node scripts/serve.mjs --target=phone --build-first"
  },
  "appHub": {
    "env": {
      "PUBLIC_DIR": "public",
      "SPA_FALLBACK": "0",
      "APP_ONE_REPOSITORY": "https://github.com/mskoh52/morse-trainer.git",
      "APP_ONE_INSTALL_COMMAND": "sh -c 'node build.js && mv dist/morse-trainer.html dist/index.html'",
      "APP_TWO_REPOSITORY": "https://github.com/mskoh52/arithmetic-practice.git"
    },
    "targets": {
      "local": {
        "HOST": "127.0.0.1",
        "PORT": "4173"
      },
      "phone": {
        "HOST": "0.0.0.0",
        "PORT": "8080"
      }
    }
  },
  "engines": {
    "node": ">=22"
  }
}
